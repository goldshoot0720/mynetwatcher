<Window
    x:Class="NetWatcher.App.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:NetWatcher.App"
    x:DataType="vm:MainWindowViewModel"
    Width="1180"
    Height="760"
    MinWidth="960"
    MinHeight="640"
    Title="最瞎結婚理由"
    Background="#F7EFE5"
    Foreground="#2C1B12"
    mc:Ignorable="d">
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <Grid RowDefinitions="Auto,Auto,*" Margin="28" RowSpacing="22">
      <Border
          Padding="30"
          CornerRadius="34"
          Background="#F2D2A9">
        <Grid ColumnDefinitions="1.35*,0.95*" ColumnSpacing="24">
          <StackPanel Spacing="14">
            <Border
                HorizontalAlignment="Left"
                Padding="14,8"
                CornerRadius="999"
                Background="#FFF7ED">
              <TextBlock
                  FontSize="13"
                  FontWeight="SemiBold"
                  Foreground="#A04A1A"
                  Text="今彩五三九牽紅線版" />
            </Border>

            <TextBlock
                MaxWidth="640"
                FontSize="40"
                FontWeight="Bold"
                TextWrapping="Wrap"
                Text="最瞎結婚理由，瞎到大家笑翻，偏偏又甜得有點合理。" />

            <TextBlock
                MaxWidth="680"
                FontSize="16"
                Foreground="#6F4B36"
                TextWrapping="Wrap"
                Text="{Binding HeroDescription}" />
          </StackPanel>

          <Border
              Grid.Column="1"
              Padding="22"
              CornerRadius="28"
              Background="#FFF8F1">
            <StackPanel Spacing="14">
              <TextBlock
                  FontSize="14"
                  FontWeight="SemiBold"
                  Foreground="#A04A1A"
                  Text="目前焦點" />
              <TextBlock
                  FontSize="28"
                  FontWeight="Bold"
                  TextWrapping="Wrap"
                  Text="{Binding HighlightedReason.Title}" />
              <TextBlock
                  FontSize="15"
                  Foreground="#6F4B36"
                  TextWrapping="Wrap"
                  Text="{Binding HighlightedReason.Reason}" />

              <WrapPanel ItemWidth="150" ItemHeight="58">
                <Border Margin="0,0,12,12" Padding="14,10" CornerRadius="18" Background="#F8E3CF">
                  <StackPanel>
                    <TextBlock Foreground="#8B5A3C" Text="篇章" />
                    <TextBlock FontWeight="Bold" Text="{Binding HighlightedReason.Category}" />
                  </StackPanel>
                </Border>
                <Border Margin="0,0,12,12" Padding="14,10" CornerRadius="18" Background="#F8E3CF">
                  <StackPanel>
                    <TextBlock Foreground="#8B5A3C" Text="標籤" />
                    <TextBlock FontWeight="Bold" Text="{Binding HighlightedReason.Vibe}" />
                  </StackPanel>
                </Border>
              </WrapPanel>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Grid Grid.Row="1" ColumnDefinitions="1.2*,0.8*" ColumnSpacing="18">
        <Border Padding="22" CornerRadius="28" Background="#FFF8F1">
          <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
              <StackPanel Spacing="4">
                <TextBlock FontSize="26" FontWeight="Bold" Text="故事選單" />
                <TextBlock Foreground="#6F4B36" Text="{Binding CategoryDescription}" />
              </StackPanel>

              <ComboBox
                  Grid.Column="1"
                  Width="180"
                  ItemsSource="{Binding Categories}"
                  SelectedItem="{Binding SelectedCategory}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:ReasonCategoryOption">
                    <TextBlock Text="{Binding Name}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <Button
                  Grid.Column="2"
                  MinWidth="110"
                  Padding="16,11"
                  Background="#D95C18"
                  Foreground="White"
                  Content="隨機抽段"
                  Command="{Binding RandomizeReasonCommand}" />

              <Button
                  Grid.Column="3"
                  MinWidth="110"
                  Padding="16,11"
                  Background="#EAD8C4"
                  Foreground="#2C1B12"
                  Content="下一段"
                  Command="{Binding NextReasonCommand}" />
            </Grid>

            <Border Grid.Row="1" Padding="14,12" CornerRadius="18" Background="#F6E7D7">
              <TextBlock
                  Foreground="#8B5A3C"
                  TextWrapping="Wrap"
                  Text="{Binding SelectionSummary}" />
            </Border>

            <ListBox
                Grid.Row="2"
                Background="Transparent"
                BorderThickness="0"
                ItemsSource="{Binding VisibleReasons}"
                SelectedItem="{Binding HighlightedReason}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:MarriageReasonItem">
                  <Border Margin="0,0,0,12" Padding="16" CornerRadius="20" Background="#FFFDF9">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                      <StackPanel Spacing="8">
                        <TextBlock FontSize="20" FontWeight="Bold" Text="{Binding Title}" />
                        <TextBlock Foreground="#6F4B36" Text="{Binding Reason}" TextWrapping="Wrap" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" VerticalAlignment="Top" Spacing="8">
                        <Border Padding="10,6" CornerRadius="999" Background="#F2D2A9">
                          <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Vibe}" />
                        </Border>
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>

        <Border Grid.Column="1" Padding="22" CornerRadius="28" Background="#2C1B12">
          <StackPanel Spacing="18">
            <TextBlock
                FontSize="26"
                FontWeight="Bold"
                Foreground="#FFF8F1"
                Text="可直接複製" />

            <Border Padding="18" CornerRadius="22" Background="#3C261B">
              <TextBlock
                  FontSize="22"
                  FontWeight="Bold"
                  Foreground="#FFDDB9"
                  TextWrapping="Wrap"
                  Text="{Binding HighlightedReason.Title}" />
            </Border>

            <TextBlock
                FontSize="16"
                Foreground="#F7D8C0"
                TextWrapping="Wrap"
                Text="{Binding ShareText}" />

            <Button
                Padding="16,12"
                Background="#FFD08B"
                Foreground="#2C1B12"
                Click="CopyReasonButton_OnClick"
                Content="複製這段" />

            <TextBlock
                Foreground="#E7B88F"
                TextWrapping="Wrap"
                Text="{Binding CopyStatus}" />
          </StackPanel>
        </Border>
      </Grid>

      <Border Grid.Row="2" Padding="22" CornerRadius="28" Background="#E9C09B">
        <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="22" FontWeight="Bold" Text="故事節奏" />
            <TextBlock Foreground="#6F4B36" TextWrapping="Wrap" Text="這版不走一句式幹話，而是保留你給的整段敘事，讓鋒兄、塗哥、思敏、蕙瑄和今彩五三九的荒謬感完整成立。" />
          </StackPanel>

          <StackPanel Grid.Column="1" Spacing="8">
            <TextBlock FontSize="22" FontWeight="Bold" Text="尾韻" />
            <TextBlock Foreground="#6F4B36" TextWrapping="Wrap" Text="最後那句『如果幸福也能這樣瞎忙，那我明天也去買一張』我也放進摘要段落裡，讓整體收尾更像你原本的版本。" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</Window>
